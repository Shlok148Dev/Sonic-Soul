# ============================
# PSYCHE Environment Variables Template
# Copy to .env and fill in real values
# NEVER commit .env to git
# ============================

# Supabase (free tier)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Upstash Redis (free tier)
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your-token-here

# Ollama (local — no key needed)
OLLAMA_HOST=http://localhost:11434

# Weights & Biases (free tier)
WANDB_API_KEY=your-wandb-key
WANDB_ENTITY=your-username

# Anthropic (free tier credits)
ANTHROPIC_API_KEY=your-api-key

# OpenWeatherMap (free tier — 60 calls/min)
OPENWEATHER_API_KEY=your-api-key

# PSYCHE API Authentication
PSYCHE_API_KEY=generate-a-random-string-here

# Vercel/Frontend
NEXT_PUBLIC_PSYCHE_API_URL=http://localhost:8000
NEXT_PUBLIC_PSYCHE_API_WS=ws://localhost:8000
